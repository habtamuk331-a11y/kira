{
  "name": "shop-manager",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
  "build": "npm run prisma:generate && npm run build --workspace client",
  "dev:client": "npm run dev --workspace client",
  "dev:server": "npm run dev --workspace server",
  "prisma:generate": "npm run prisma:generate --workspace server",
  "prisma:migrate": "npm run prisma:migrate --workspace server"
},
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "prisma": "5.7.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
